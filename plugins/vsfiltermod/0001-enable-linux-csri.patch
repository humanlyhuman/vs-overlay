From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Subject: [PATCH] add standalone Linux CSRI build target

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1111111..2222222 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -8,6 +8,7 @@ set(CMAKE_POSITION_INDEPENDENT_CODE ON)

 # Common options
 option(VSFILTERMOD_BUILD_DIRECTSHOW "Build DirectShow filter (Windows only)" ON)
+option(VSFILTERMOD_BUILD_CSRI "Build standalone CSRI renderer" ON)

 # On non-Windows, disable DirectShow components
 if(NOT WIN32)
@@ -82,6 +83,11 @@ add_subdirectory(src/platform)
 # Cross-platform VapourSynth/AviSynth plugin
 add_subdirectory(src/plugins)

+# Standalone CSRI build (Linux/macOS)
+if(VSFILTERMOD_BUILD_CSRI)
+    add_subdirectory(src/csri)
+endif()
+
 # Windows DirectShow filter
 if(VSFILTERMOD_BUILD_DIRECTSHOW)
     add_subdirectory(src/vsfilter)
diff --git a/src/csri/CMakeLists.txt b/src/csri/CMakeLists.txt
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/src/csri/CMakeLists.txt
@@ -0,0 +1,34 @@
+add_library(vsfiltermod-csri SHARED
+    ../vsfilter/csriapi.cpp
+)
+
+target_include_directories(vsfiltermod-csri PRIVATE
+    ${CMAKE_SOURCE_DIR}/src/compat
+    ${CMAKE_SOURCE_DIR}/src/subtitles
+    ${CMAKE_SOURCE_DIR}/src/subpic
+    ${CMAKE_SOURCE_DIR}/src/platform
+    ${CMAKE_SOURCE_DIR}/src/vsfilter
+    ${CMAKE_SOURCE_DIR}/src/zlib
+    ${CMAKE_SOURCE_DIR}/src/libpng
+)
+
+target_link_libraries(vsfiltermod-csri PRIVATE
+    subtitles
+    subpic
+    platform
+    libssf
+    libpng
+    zlib
+)
+
+set_target_properties(vsfiltermod-csri PROPERTIES
+    OUTPUT_NAME "vsfiltermod-csri"
+    PREFIX "lib"
+)
+
+install(TARGETS vsfiltermod-csri
+    LIBRARY DESTINATION lib
+)
